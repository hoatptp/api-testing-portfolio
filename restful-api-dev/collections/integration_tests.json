            "url": {
              "raw": "{{BASE_URL}}/objects/{{new_object_id}}",
              "host": ["{{BASE_URL}}"],
              "path": ["objects", "{{new_object_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[Flow 3 - Step 3] Status code is 404 - cannot update deleted object', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.collectionVariables.set('new_object_id', '');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
