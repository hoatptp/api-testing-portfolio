          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Object to delete then update\",\n    \"data\": { \"price\": 100 }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{BASE_URL}}/objects",
              "host": ["{{BASE_URL}}"],
              "path": ["objects"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[Flow 3 - Step 1] Status code is 200', function () {",
