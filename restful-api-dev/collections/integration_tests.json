                  "pm.collectionVariables.set('new_object_id', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "[Flow 3 - Step 2] DELETE: Delete the object",
          "request": {
            "method": "DELETE",
