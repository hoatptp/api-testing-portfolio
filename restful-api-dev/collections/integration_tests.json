                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "[Flow 3 - Step 3] PUT: Try to update deleted object",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Should not work\"\n}",
              "options": { "raw": { "language": "json" } }
