{
  "info": {
    "name": "restful-api.dev - Contract Tests",
    "_postman_id": "contract-tests-restful-api-dev-001",
    "description": "Contract tests cho restful-api.dev public endpoints. Chỉ verify structure của response: field có tồn tại không, data type có đúng không. Không test behavior hay logic.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://api.restful-api.dev",
      "type": "string"
    },
    {
      "key": "stable_object_id",
      "value": "7",
      "type": "string",
      "description": "Pre-seeded fixture ID. ID 7 = Apple MacBook Pro 16"
    },
    {
      "key": "new_object_id",
      "value": "",
      "type": "string",
      "description": "Set tự động sau khi POST, dùng cho PUT/PATCH/DELETE"
    }
  ],
  "item": [
    {
      "name": "GET /objects - contract",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/objects",
          "host": ["{{BASE_URL}}"],
          "path": ["objects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('Response is an array', function () {",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test('Each object has id as string', function () {",
              "    jsonData.forEach(function(obj) {",
              "        pm.expect(obj.id).to.be.a('string');",
              "    });",
              "});",
              "",
              "pm.test('Each object has name as string', function () {",
              "    jsonData.forEach(function(obj) {",
              "        pm.expect(obj.name).to.be.a('string');",
              "    });",
              "});",
              "",
              "pm.test('Each object data field is object or null', function () {",
              "    jsonData.forEach(function(obj) {",
              "        pm.expect(obj.data === null || typeof obj.data === 'object').to.be.true;",
              "    });",
              "});",
              "",
              "pm.test('No unexpected top-level fields on each object', function () {",
              "    const allowedFields = ['id', 'name', 'data'];",
              "    jsonData.forEach(function(obj) {",
              "        Object.keys(obj).forEach(function(key) {",
              "            pm.expect(allowedFields).to.include(key);",
              "        });",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
