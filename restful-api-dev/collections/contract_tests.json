    {
      "name": "POST /objects - contract",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Contract Test Object\",\n    \"data\": {\n        \"year\": 2023,\n        \"price\": 999.99\n    }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{BASE_URL}}/objects",
          "host": ["{{BASE_URL}}"],
          "path": ["objects"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test('id is a string', function () {",
              "    pm.expect(jsonData.id).to.be.a('string');",
              "});",
              "",
              "pm.test('name is a string', function () {",
              "    pm.expect(jsonData.name).to.be.a('string');",
              "});",
              "",
              "pm.test('data is object or null', function () {",
              "    pm.expect(jsonData.data === null || typeof jsonData.data === 'object').to.be.true;",
              "});",
              "",
              "pm.test('createdAt is a string', function () {",
              "    pm.expect(jsonData.createdAt).to.be.a('string');",
              "});",
              "",
              "pm.test('createdAt is valid ISO 8601 format', function () {",
              "    pm.expect(new Date(jsonData.createdAt).toString()).to.not.eql('Invalid Date');",
              "});",
              "",
              "pm.test('No unexpected top-level fields', function () {",
              "    const allowedFields = ['id', 'name', 'data', 'createdAt'];",
              "    Object.keys(jsonData).forEach(function(key) {",
              "        pm.expect(allowedFields).to.include(key);",
              "    });",
              "});",
              "",
              "pm.collectionVariables.set('new_object_id', jsonData.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
